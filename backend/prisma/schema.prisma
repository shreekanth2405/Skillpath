generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String   @id @default(uuid())
  name                    String
  email                   String   @unique
  password                String
  role                    String   @default("user")
  phone                   String?
  department              String?
  experienceLevel         String?
  preferredRole           String[]
  skills                  String[]
  preferredLocation       String[]
  notificationEmail       Boolean  @default(true)
  notificationWhatsapp    Boolean  @default(true)
  minScoreThreshold       Int      @default(80)
  xp                      Int      @default(0)
  level                   Int      @default(1)
  coins                   Int      @default(0)
  createdAt               DateTime @default(now())

  jobMatches              JobMatch[]
  commSessions            CommunicationSession[]
  habits                  Habit[]
  testResults             TestResult[]
  resumes                 Resume[]
  bookmarks               Bookmark[]
  labSubmissions          LabSubmission[]
  
  // Events
  createdEvents           Event[]              @relation("EventCreator")
  eventRegistrations      EventRegistration[]
}

model Event {
  id               String   @id @default(uuid())
  title            String
  organizer        String
  description      String?
  date             DateTime
  time             String
  mode             String   @default("Online") // Online, Offline, Hybrid
  location         String?
  type             String   // Conference, Hackathon, Workshop, etc.
  category         String   // AI & Tech, Career, etc.
  price            String   @default("Free")
  image            String?
  recommended      Boolean  @default(false)
  speakers         String[] // Array of speaker names/details

  creatorId        String
  createdAt        DateTime @default(now())

  creator          User                @relation("EventCreator", fields: [creatorId], references: [id])
  registrations    EventRegistration[]
}

model EventRegistration {
  id           String   @id @default(uuid())
  userId       String
  eventId      String
  status       String   @default("Registered") // Registered, Attended, Cancelled
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Bookmark {
  id           String   @id @default(uuid())
  userId       String
  title        String
  category     String?
  sourceUrl    String?  // For Archive.org link if applicable
  isArchiveOrg Boolean  @default(false)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id                 String     @id @default(uuid())
  sourceUrl          String     @unique
  sourceDomain       String
  companyName        String
  jobTitle           String
  location           String[]
  experienceRequired String?
  skillsRequired     String[]
  rawDescription     String?
  postedAt           DateTime?
  discoveredAt       DateTime   @default(now())
  isDuplicate        Boolean    @default(false)

  matches            JobMatch[]
}

model JobMatch {
  id             String    @id @default(uuid())
  userId         String
  jobId          String
  relevanceScore Float
  matchStatus    String    @default("New")
  skillGap       String[]
  notified       Boolean   @default(false)
  notifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id])
  job            Job       @relation(fields: [jobId], references: [id])
}

model CommunicationSession {
  id              String   @id @default(uuid())
  userId          String
  topic           String
  fluencyWpm      Int?
  grammarScore    Float?
  vocabComplexity String?
  confidenceIndex Float?
  history         Json?     
  finalCefrLevel  String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model Habit {
  id                String   @id @default(uuid())
  userId            String
  title             String
  category          String
  frequency         String
  streak            Int      @default(0)
  completedToday    Boolean  @default(false)
  totalDone         Int      @default(0)
  target            Int      @default(30)
  xpPerCompletion   Int      @default(30)
  color             String?
  reminder          String?
  lastCompletedAt   DateTime?
  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id])
}

model TestResult {
  id              String   @id @default(uuid())
  userId          String
  type            String   // 'Quiz' or 'CodingChallenge'
  topic           String
  score           Int?     // For quizzes
  totalQuestions  Int?     // For quizzes
  passed          Boolean? // For coding challenges
  feedback        String?  // For coding challenges
  codeSubmitted   String?  // For coding challenges
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model Resume {
  id              String   @id @default(uuid())
  userId          String
  name            String
  template        String   @default("modern")
  content         Json     // Store the generated resume data
  atsScore        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
}

model Certification {
  id          String   @id @default(uuid())
  title       String
  provider    String
  category    String
  level       String
  link        String
  createdAt   DateTime @default(now())
}
model Lab {
  id              String   @id @default(uuid())
  roomNumber      Int      @unique
  title           String
  description     String
  domain          String   // e.g., 'Web Development', 'Data Science', 'Networking', 'Cybersecurity'
  difficulty      String   // e.g., 'Beginner', 'Intermediate', 'Advanced'
  instructions    String?  @db.Text
  tasks           Json?    // Array of tasks/steps
  starterCode     String?  @db.Text
  solution        String?  @db.Text
  xpReward        Int      @default(150)
  createdAt       DateTime @default(now())

  submissions     LabSubmission[]
}

model LabSubmission {
  id              String   @id @default(uuid())
  labId           String
  userId          String
  status          String   @default("Pending") // Pending, Completed, Failed
  code            String?  @db.Text
  notes           String?  @db.Text
  feedback        String?
  createdAt       DateTime @default(now())

  lab             Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
